#!/usr/bin/env bash
# Pre-commit safety net for the public repo.
#
# Blocks staged files matching patterns that should NEVER reach a public
# branch. The .gitignore is the first defence; this hook catches the case
# where someone runs `git add -f`, a tool stages a file before .gitignore
# was updated, or a path is added before the pattern is updated.
#
# Activated by `git config core.hooksPath .githooks` (set automatically
# by `npm install` postinstall â€” see package.json).
#
# To bypass on a specific commit (only do this if you understand why):
#   git commit --no-verify

set -euo pipefail

# Patterns that should never be in a public commit. Each is checked against
# the full path of every staged file. Pattern syntax is bash regex.
FORBIDDEN_PATTERNS=(
  '^\.routines/'
  '^\.local/'
  '^\.claude/'
  '^\.cursor/'
  '^\.aider'
  '^\.playwright-mcp/'
  '^CLAUDE\.md$'
  '^claude\.md$'
  '^AGENTS\.md$'
  '^agents\.md$'
  '^MEMORY\.md$'
  '^TASKS\.md$'
  '^ROUTINE\.md$'
  '^OPS-ROUTINE\.md$'
  '^\.env$'
  '^\.env\.[^.]+$'
  '\.db$'
  '\.sqlite[0-9]*$'
  '\.dump$'
  '\.sql\.gz$'
  '^id_(rsa|ed25519|ecdsa)'
  '\.ppk$'
  '\.pfx$'
  '\.p12$'
  '^authorized_keys$'
  '\.sentryclirc$'
  '^\.env\.sentry-build-plugin$'
)

# .env.example is the one allowed exception
ALLOW_PATTERNS=(
  '^\.env\.example$'
)

# Collect staged paths (added, copied, modified, renamed). 'D'eleted are fine.
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMR)

violations=()
for path in "${staged[@]}"; do
  # Allow-list check first
  for allow in "${ALLOW_PATTERNS[@]}"; do
    if [[ "$path" =~ $allow ]]; then
      continue 2
    fi
  done
  # Forbidden check
  for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ "$path" =~ $pattern ]]; then
      violations+=("$path -> matches /$pattern/")
      break
    fi
  done
done

if (( ${#violations[@]} > 0 )); then
  echo
  echo "ERROR: Refusing to commit. The following staged paths look private:"
  for v in "${violations[@]}"; do
    printf '  %s\n' "$v"
  done
  echo
  echo "If this is a false positive, edit .githooks/pre-commit to refine the"
  echo "patterns, or commit with --no-verify after double-checking."
  exit 1
fi

# --- Content scan ----------------------------------------------------------
# The path check above catches a whole file that shouldn't exist (.env, a
# key, a DB dump). It does NOT catch a secret pasted INTO an
# innocent-looking file â€” an API key in a .ts test fixture, a private key
# in a config snippet. This second pass greps the *added lines* of the
# staged diff for secret-shaped strings.
#
# Only high-confidence patterns: provider-prefixed keys and PEM headers
# that never legitimately appear in source. The generic
# "SECRET = '<long string>'" shape is deliberately NOT matched â€” the repo
# has legit placeholders (fallback-secret-change-me, ci-only-...,
# replace-with-...) and matching it would train contributors to
# --no-verify past the hook, which defeats the point.
SECRET_PATTERNS=(
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'   # any PEM private key
  'AKIA[0-9A-Z]{16}'                     # AWS access key id
  'AIza[0-9A-Za-z_-]{35}'                # Google API key
  'sk_live_[0-9a-zA-Z]{20,}'             # Stripe live secret key
  'ghp_[0-9A-Za-z]{36}'                  # GitHub personal access token
  'xox[baprs]-[0-9A-Za-z-]{10,}'         # Slack token
)
# Added lines only (`+` prefix), minus the `+++ b/file` diff headers.
added=$(git diff --cached --diff-filter=ACMR -U0 | grep -E '^\+' | grep -vE '^\+\+\+' || true)
secret_hits=()
for pat in "${SECRET_PATTERNS[@]}"; do
  # `-e` is required â€” the PEM pattern starts with `-`, which grep would
  # otherwise treat as an option flag.
  if echo "$added" | grep -qE -e "$pat"; then
    secret_hits+=("$pat")
  fi
done
if (( ${#secret_hits[@]} > 0 )); then
  echo
  echo "ERROR: Refusing to commit. Staged changes contain secret-shaped strings:"
  for h in "${secret_hits[@]}"; do printf '  matches /%s/\n' "$h"; done
  echo
  echo "If a real credential leaked: remove it, then ROTATE the key â€” assume"
  echo "it is already burned the moment it touches a commit. If it is a false"
  echo "positive (a sample value in docs), commit with --no-verify after"
  echo "confirming the string is not a live credential."
  exit 1
fi

exit 0
