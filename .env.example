# Copy this file to .env.local for local dev, or to .env.production on the
# server. Keep your real values in .local/secrets/ — never commit .env files.

# === Auth ===
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-strong-random-32-byte-hex-string

# === Cron ===
# Used by /api/calendar/cron — only requests with ?secret=<this> are accepted
# (or Vercel's built-in cron header). Generate the same way as JWT_SECRET.
CRON_SECRET=replace-with-strong-random-32-byte-hex-string

# === AI / passport extraction ===
# Get a free key at https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to "gemini-2.5-flash".
# Note: gemini-2.0-flash is DEPRECATED and shuts down 2026-06-01.
# Free tier is generous (1500 req/day, 1M tokens/min). Paid tier is
# ~$0.0002 per passport extraction. https://ai.google.dev/gemini-api/docs/pricing
# GEMINI_MODEL=gemini-2.5-flash

# === Database ===
# Pick ONE of the two configurations below.

# A) Self-hosted SQLite (recommended for DO droplet / single-server)
# DATABASE_URL=file:./data/prod.db

# B) Turso / libSQL (hosted, used during the Vercel deployment)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# === Error tracking (optional) ===
# Get a DSN at https://sentry.io — Settings → Client Keys (DSN).
# Free tier: 5k errors/month. Leave blank to disable Sentry entirely.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: auth token for uploading source maps (so stack traces show TS, not minified JS).
# Sentry → Settings → Auth Tokens → "Create New Token" with project:releases scope.
SENTRY_AUTH_TOKEN=
