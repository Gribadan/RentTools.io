  "scripts": {
    "dev": "next dev",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'ignore'})}catch(e){}\"",
    "postinstall": "prisma generate",
    "build": "next build",
    "db:push": "tsx prisma/push-schema.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-blog": "tsx prisma/seed-blog-posts.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/generative-ai": "0.24.1",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/nextjs": "^10.51.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "prisma": "7.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
