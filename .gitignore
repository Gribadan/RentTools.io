# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# This file is the FIRST line of defence against accidentally committing
# secrets, internal notes, or AI-tool config to a public repo. The second
# line is .githooks/pre-commit (auto-installed via `npm install` postinstall).
# The third is the CI check in .github/workflows/ci.yml.
# Add new forbidden patterns to ALL THREE places when you find a leak.

# === Dependencies & build artifacts ===
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts
/src/generated/
.swc/

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === OS / IDE ===
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/
*.swp
*.swo
*~

# === AI / dev-tool config (NEVER public) ===
# Claude Code, Anthropic Agent SDK, Cursor, GitHub Copilot internal config,
# any tool that drops a config file at the project root.
CLAUDE.md
claude.md
Claude.md
.claude/
AGENTS.md
agents.md
.cursor/
.cursorrules
.cursor-tutor
.aider*
.continue/
.copilot/

# === Internal task tracking / AI agent prompts ===
# Routine prompts, task backlogs, ops runbooks — useful internally,
# noise + clutter for public users.
.routines/
ROUTINE.md
TASKS.md
OPS-ROUTINE.md

# === Local-only personal stuff ===
# Everything inside .local/ stays local. Do NOT add a !exception here —
# the previous repo had .local/README.md tracked which leaked the layout
# of secret files. If you need to document the .local/ layout, do it in
# the main README's "self-host" section instead.
.local/

# === MCP / testing artifacts ===
.playwright-mcp/
.mcp/
playwright-report/
test-results/

# === Env files (only .env.example may ever be committed) ===
.env
.env.*
!.env.example

# === Databases ===
*.db
*.db-journal
*.sqlite
*.sqlite3
/dev.db
/data/

# === Backups & dumps ===
/backups/
*.dump
*.sql
*.sql.gz
*.tar.gz
*.zip

# === Sentry build artifacts ===
.env.sentry-build-plugin
.sentryclirc

# === SSH / signing keys (never, under any circumstance) ===
id_rsa*
id_ed25519*
id_ecdsa*
*.ppk
*.pfx
*.p12
*.cer
authorized_keys

# === Auto-generated memory / scratch ===
# Anthropic Memory tool may write MEMORY.md to the project — block it.
MEMORY.md
memory.md
.memory/

# === Vercel ===
.vercel
