generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("user") // "superadmin" or "user"
  createdAt DateTime @default(now())
}

model AppSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Property {
  id           Int           @id @default(autoincrement())
  name         String
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

model Reservation {
  id         Int      @id @default(autoincrement())
  name       String
  checkIn    DateTime
  checkOut   DateTime
  platform   String   @default("airbnb")
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guests     Guest[]
  createdAt  DateTime @default(now())
}

model Guest {
  id               Int         @id @default(autoincrement())
  fullName         String
  firstName        String      @default("")
  lastName         String      @default("")
  country          String
  citizenshipCode  String      @default("")
  dateOfBirth      String
  yearsOld         Int
  gender           String      @default("")
  dateOfIssue      String
  expiryDate       String
  passportNumber   String
  issuedBy         String
  visaNumber       String      @default("")
  visaFrom         String      @default("")
  visaTo           String      @default("")
  hasVisa          Boolean     @default(false)
  parentId         Int?
  reservationId    Int
  reservation      Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
}
