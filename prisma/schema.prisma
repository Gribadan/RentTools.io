generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 Int                  @id @default(autoincrement())
  username           String               @unique
  password           String
  role               String               @default("user") // "superadmin" | "user" | "cleaner"
  email              String?              // optional; populated by Google sign-in (RT-16.5) or future profile edits
  googleId           String?              @unique // Google subject (sub) ID — set when user signs in with Google
  createdAt          DateTime             @default(now())
  lastLoginAt        DateTime?
  suspendedAt        DateTime?
  alertsDismissedAt  DateTime?
  properties         Property[]
  cleanerAssignments CleanerAssignment[]  @relation("CleanerAssignments")
  managedProperties  PropertyManager[]    @relation("ManagerAssignments")
  grantedManagers    PropertyManager[]    @relation("ManagerGrants")
  createdInvites     PropertyManagerInvite[] @relation("InviteCreators")
  acceptedInvites    PropertyManagerInvite[] @relation("InviteAcceptors")
}

model AppSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// Global site-wide configuration. Distinct from AppSettings (which is bound
// to the legacy Gemini key/model lookup) so the admin UI can manage these
// keys without touching the existing extraction pipeline.
model SiteSetting {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     String
  updatedAt DateTime?
}

model Property {
  id             Int              @id @default(autoincrement())
  userId         Int
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  minNights      Int              @default(3)
  checkInTime    String           @default("14:00")
  checkOutTime   String           @default("12:00")
  bookingWindow  Int              @default(365) // days forward from today to accept bookings; beyond this, events are ignored
  feedToken      String?          @unique // optional opt-in token gating the public iCal feed; null = public
  createdAt      DateTime         @default(now())
  updatedAt      DateTime?
  reservations       Reservation[]
  calendarLinks      CalendarLink[]
  calendarEvents     CalendarEvent[]
  dateOverrides      DateOverride[]
  cleanerAssignments CleanerAssignment[]
  cleaningRecords    CleaningRecord[]
  messageTemplates   MessageTemplate[]
  managers           PropertyManager[]
  managerInvites     PropertyManagerInvite[]

  @@index([userId])
}

model PropertyManager {
  id          Int      @id @default(autoincrement())
  propertyId  Int
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  managerId   Int
  manager     User     @relation("ManagerAssignments", fields: [managerId], references: [id], onDelete: Cascade)
  grantedById Int
  grantedBy   User     @relation("ManagerGrants", fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([managerId, propertyId])
  @@index([propertyId])
  @@index([managerId])
}

model PropertyManagerInvite {
  id           Int       @id @default(autoincrement())
  propertyId   Int
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  token        String    @unique
  createdById  Int
  createdBy    User      @relation("InviteCreators", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedById Int?      // null until accepted; references the user who accepted
  acceptedBy   User?     @relation("InviteAcceptors", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedAt   DateTime?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([propertyId])
  @@index([token])
}

model MessageTemplate {
  id             Int      @id @default(autoincrement())
  propertyId     Int
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name           String
  language       String   @default("en")
  subject        String   @default("")
  body           String
  sendOffsetDays Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime?

  @@index([propertyId])
}

model CleaningRecord {
  id            Int      @id @default(autoincrement())
  propertyId    Int
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date          String   // YYYY-MM-DD
  status        String   @default("pending") // "pending" | "done" | "skipped"
  doneAt        DateTime?
  doneByUserId  Int?
  notes         String   @default("")
  photos        String   @default("[]") // JSON array of URLs
  createdAt     DateTime @default(now())
  updatedAt     DateTime?

  @@unique([propertyId, date])
  @@index([propertyId, date])
}

model CleanerAssignment {
  id         Int      @id @default(autoincrement())
  cleanerId  Int
  cleaner    User     @relation("CleanerAssignments", fields: [cleanerId], references: [id], onDelete: Cascade)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([cleanerId, propertyId])
  @@index([cleanerId])
  @@index([propertyId])
}

model CalendarLink {
  id            Int       @id @default(autoincrement())
  propertyId    Int
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform      String    // "airbnb" or "booking"
  icalExportUrl String    // iCal export URL from the platform
  bufferBefore  Int       @default(1) // days before booking to block
  bufferAfter   Int       @default(1) // days after booking to block
  lastFetchedAt DateTime?
  lastError     String?
  failureCount  Int       @default(0)
  createdAt     DateTime  @default(now())
}

model CalendarEvent {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform   String   // source platform
  uid        String   // iCal event UID
  summary    String   @default("")
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  createdAt  DateTime @default(now())

  @@unique([propertyId, platform, uid])
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  propertyId Int?
  level      String   @default("info") // "info", "warn", "error", "success"
  message    String
  createdAt  DateTime @default(now())
}

model Reservation {
  id              Int      @id @default(autoincrement())
  name            String
  checkIn         DateTime
  checkOut        DateTime
  platform        String   @default("airbnb")
  linkedEventUid  String?  // UID of a synced CalendarEvent this reservation extends (for direct-pay extensions)
  propertyId      Int
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guests          Guest[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DateOverride {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date       String   // YYYY-MM-DD
  type       String   // "open" or "closed"
  note       String   @default("")
  createdAt  DateTime @default(now())

  @@unique([propertyId, date])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  action       String   // "create" | "update" | "delete"
  resourceType String   // "property" | "reservation" | "guest" | "override" | "calendarLink"
  resourceId   Int
  payload      String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Guest {
  id               Int         @id @default(autoincrement())
  fullName         String
  firstName        String      @default("")
  lastName         String      @default("")
  country          String
  citizenshipCode  String      @default("")
  dateOfBirth      String
  yearsOld         Int
  gender           String      @default("")
  dateOfIssue      String
  expiryDate       String
  passportNumber   String
  issuedBy         String
  visaNumber       String      @default("")
  visaFrom         String      @default("")
  visaTo           String      @default("")
  hasVisa          Boolean     @default(false)
  parentId         Int?
  reservationId    Int
  reservation      Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// Anonymous pre-signup wizard state. Created when a visitor starts
// /onboard, claimed by the signup endpoint when they create an account
// (the draft's links + propertyName are materialised as a real Property
// + CalendarLinks). Drafts older than 14 days with no claim are
// candidates for cleanup, but pruning is opportunistic, not enforced.
model OnboardingDraft {
  id              Int       @id @default(autoincrement())
  sessionToken    String    @unique
  propertyName    String    @default("")
  links           String    @default("[]") // JSON array of { platform, icalExportUrl }
  claimedByUserId Int?
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime?
}

// One row per /api/extract POST. Powers the daily per-user rate limit
// (RT-15.5) and gives admins an audit trail of who pushed what through
// the Gemini pipeline. No FK to User on purpose so deleting a user
// doesn't lose audit history.
model ExtractionLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  fileCount Int      @default(0)
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
