generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("user") // "superadmin" or "user"
  createdAt DateTime @default(now())
}

model AppSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Property {
  id             Int              @id @default(autoincrement())
  name           String
  minNights      Int              @default(3)
  createdAt      DateTime         @default(now())
  reservations   Reservation[]
  calendarLinks  CalendarLink[]
  calendarEvents CalendarEvent[]
  dateOverrides  DateOverride[]
}

model CalendarLink {
  id            Int       @id @default(autoincrement())
  propertyId    Int
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform      String    // "airbnb" or "booking"
  icalExportUrl String    // iCal export URL from the platform
  bufferBefore  Int       @default(1) // days before booking to block
  bufferAfter   Int       @default(1) // days after booking to block
  lastFetchedAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
}

model CalendarEvent {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform   String   // source platform
  uid        String   // iCal event UID
  summary    String   @default("")
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  createdAt  DateTime @default(now())

  @@unique([propertyId, platform, uid])
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  propertyId Int?
  level      String   @default("info") // "info", "warn", "error", "success"
  message    String
  createdAt  DateTime @default(now())
}

model Reservation {
  id         Int      @id @default(autoincrement())
  name       String
  checkIn    DateTime
  checkOut   DateTime
  platform   String   @default("airbnb")
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guests     Guest[]
  createdAt  DateTime @default(now())
}

model DateOverride {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date       String   // YYYY-MM-DD
  type       String   // "open" or "closed"
  note       String   @default("")
  createdAt  DateTime @default(now())

  @@unique([propertyId, date])
}

model Guest {
  id               Int         @id @default(autoincrement())
  fullName         String
  firstName        String      @default("")
  lastName         String      @default("")
  country          String
  citizenshipCode  String      @default("")
  dateOfBirth      String
  yearsOld         Int
  gender           String      @default("")
  dateOfIssue      String
  expiryDate       String
  passportNumber   String
  issuedBy         String
  visaNumber       String      @default("")
  visaFrom         String      @default("")
  visaTo           String      @default("")
  hasVisa          Boolean     @default(false)
  parentId         Int?
  reservationId    Int
  reservation      Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
}
